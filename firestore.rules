rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Fallback: checks user profile for linked studentIds (for old docs without parentUserIds)
    function isLinkedParent(studentId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.keys().hasAll(['studentIds']) && userData.studentIds.hasAny([studentId]);
    }

    // Fallback: checks user profile for adminClassIds (for old docs without invitedTeacherIds)
    function isAdminOfClass(classId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.keys().hasAll(['adminClassIds']) && userData.adminClassIds.hasAny([classId]);
    }

    // Field-based: user's uid is in parentUserIds array on the document
    function isInParentUserIds(data) {
      return data.keys().hasAll(['parentUserIds']) && request.auth.uid in data.parentUserIds;
    }

    // Field-based: user's uid is in invitedTeacherIds array on the document
    function isInInvitedTeacherIds(data) {
      return data.keys().hasAll(['invitedTeacherIds']) && request.auth.uid in data.invitedTeacherIds;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // Classes collection
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.teacherId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isAdminOfClass(classId)
      );
      allow delete: if isAuthenticated() &&
        resource.data.teacherId == request.auth.uid;
    }

    // Students collection
    match /students/{studentId} {
      allow read: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isInParentUserIds(resource.data) ||
        isInInvitedTeacherIds(resource.data) ||
        isLinkedParent(studentId) ||
        isAdminOfClass(resource.data.classId)
      );
      allow create: if isAuthenticated() && (
        request.resource.data.teacherId == request.auth.uid ||
        isInInvitedTeacherIds(request.resource.data) ||
        isAdminOfClass(request.resource.data.classId)
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isInInvitedTeacherIds(resource.data) ||
        isAdminOfClass(resource.data.classId)
      );
    }

    // Homework collection
    match /homework/{homeworkId} {
      allow read: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isInParentUserIds(resource.data) ||
        isInInvitedTeacherIds(resource.data) ||
        isLinkedParent(resource.data.studentId) ||
        isAdminOfClass(resource.data.classId)
      );
      allow create: if isAuthenticated() && (
        request.resource.data.teacherId == request.auth.uid ||
        isInInvitedTeacherIds(request.resource.data) ||
        isAdminOfClass(request.resource.data.classId)
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isInInvitedTeacherIds(resource.data) ||
        isAdminOfClass(resource.data.classId)
      );
    }

    // Attendance collection
    match /attendance/{attendanceId} {
      allow read: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isInParentUserIds(resource.data) ||
        isInInvitedTeacherIds(resource.data) ||
        isLinkedParent(resource.data.studentId) ||
        isAdminOfClass(resource.data.classId)
      );
      allow create: if isAuthenticated() && (
        request.resource.data.teacherId == request.auth.uid ||
        isInInvitedTeacherIds(request.resource.data) ||
        isAdminOfClass(request.resource.data.classId)
      );
      allow update, delete: if isAuthenticated() && (
        resource.data.teacherId == request.auth.uid ||
        isInInvitedTeacherIds(resource.data) ||
        isAdminOfClass(resource.data.classId)
      );
    }

    // Invites collection - for parent invitation tracking
    match /invites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Teacher invites collection - for shared class access tracking
    match /adminInvites/{inviteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
  }
}
